<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/profilefield_repeatable/db" VERSION="2026030600" COMMENT="XMLDB file for local_profilefield_repeatable"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_profilefield_repeatable_domain" COMMENT="Reference domains for repeatable profile field lookups">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="shortname" TYPE="char" LENGTH="100" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="shortname_uix" UNIQUE="true" FIELDS="shortname"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_profilefield_repeatable_item" COMMENT="Reference code-label pairs by domain">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="domainid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="code" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="label" TYPE="text" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="domainid_fk" TYPE="foreign" FIELDS="domainid" REFTABLE="local_profilefield_repeatable_domain" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="domainid_code_uix" UNIQUE="true" FIELDS="domainid, code"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
