{{!
    @template local_profilefield_repeatable/manage

    Lists existing reference domains. Forms are rendered server-side via moodleform.

    Example context (json):
    {
        "existingdomains": "Existing domains",
        "shortname": "Shortname",
        "name": "Name",
        "timemodified": "Time modified",
        "none": "None",
        "hasdomains": true,
        "domains": [
            {
                "shortname": "diretoria",
                "name": "Diretoria",
                "timemodified": "2 April 2026"
            }
        ]
    }
}}
<h3 class="h5 mt-4">{{existingdomains}}</h3>

{{#hasdomains}}
<table class="table table-striped">
    <thead>
        <tr>
            <th>{{shortname}}</th>
            <th>{{name}}</th>
            <th>{{timemodified}}</th>
        </tr>
    </thead>
    <tbody>
        {{#domains}}
        <tr>
            <td>{{shortname}}</td>
            <td>{{name}}</td>
            <td>{{timemodified}}</td>
        </tr>
        {{/domains}}
    </tbody>
</table>
{{/hasdomains}}

{{^hasdomains}}
<div class="alert alert-info" role="alert">{{none}}</div>
{{/hasdomains}}
